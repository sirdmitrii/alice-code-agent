# Сессия Алисы добывается автоматически: при первом запуске откроется окно
# браузера, ты логинишься в Яндекс — логин сохраняется в профиле .alice_profile/,
# токен дальше обновляется сам. Креды кэшируются в .alice_creds.json.
#
# Эти поля заполнять НЕ нужно — они только для ручного override (если впишешь
# ALICE_AUTH_TOKEN, автоматический вход через браузер отключится):
ALICE_AUTH_TOKEN=
ALICE_UUID=
ALICE_ICOOKIE=
ALICE_SAE_COOKIE=
ALICE_COOKIES=

# --- Прочее (можно не трогать) ---

# Шлюз uniproxy
ALICE_WS_URL=wss://uniproxy.alice.yandex.ru/uni.ws

# Режим Алисы 2.0: Pro или пусто (обычный)
ALICE_MODE=Pro

# Переиспользовать конкретный диалог; пусто = новый диалог на каждый запрос
ALICE_DIALOG_ID=

# как агент называет модель
ALICE_MODEL_NAME=alice

# порт локального адаптера
PORT=8787

# рабочая папка проекта; пусто = папка, из которой запущен агент
PROJECT_DIR=

# Команда проверки после правок (тесты/линт/сборка). Если задана и агент менял
# файлы — выполнится; при ошибке вывод уйдёт Алисе на исправление. Пусто = выкл.
# Примеры: python -m pyflakes .   |   npm test   |   pytest -q
ALICE_VERIFY_CMD=
